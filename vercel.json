{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": "frontend",
  "public": false,
  "env": {
    "VITE_BACKEND_URL": "@vite_backend_url"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
